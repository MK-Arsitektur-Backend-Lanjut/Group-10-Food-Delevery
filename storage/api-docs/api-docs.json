                        "example": 1
                    },
                    "restaurant_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "menu_category_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Nasi Goreng"
                    },
                    "price": {
                        "type": "number",
                        "format": "float",
                        "example": 25000
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    },
                    "is_available": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "ValidateOrderItemsRequest": {
                "required": [
                    "restaurant_id",
                    "items"
                ],
                "properties": {
                    "restaurant_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "items": {
                        "type": "array",
                        "items": {
                            "required": [
                                "menu_item_id",
                                "qty"
                            ],
                            "properties": {
                                "menu_item_id": {
                                    "type": "integer",
                                    "example": 101
                                },
                                "qty": {
                                    "type": "integer",
                                    "example": 2
