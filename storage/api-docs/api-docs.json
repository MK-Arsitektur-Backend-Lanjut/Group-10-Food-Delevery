    "paths": {
        "/internal/order-items/validate": {
            "post": {
                "tags": [
                    "Internal Integration"
                ],
                "summary": "Validate requested order items",
                "description": "Internal endpoint to validate if the restaurant is open and if all requested menu items are available. Combines duplicates inside payload automatically.",
                "operationId": "db3be0a1313bc1d6539f06b711576532",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ValidateOrderItemsRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Validation passed successfully (or normalized successfully)",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "valid": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "restaurant": {
                                            "type": "object"
                                        },
                                        "items": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation failed (e.g., restaurant closed, item unavailable)",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "valid": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "errors": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
